<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/brand_card"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Nombre + botón eliminar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPackName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/tvStickerCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/brand_on_surface_dim"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnDeletePack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="@drawable/bg_delete_btn"
                android:contentDescription="Eliminar pack"/>
        </LinearLayout>

        <!-- Stickers (scroll horizontal) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:id="@+id/stickerRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="4dp"/>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvNoStickers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sin stickers aún. Agregá uno desde la pantalla principal."
            android:textSize="13sp"
            android:textColor="@color/brand_on_surface_dim"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddSticker"
                style="@style/Widget.StickerApp.Button.Outline"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="+ Agregar"
                android:textSize="13sp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendPack"
                style="@style/Widget.StickerApp.Button.Send"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="💬 WhatsApp"
                android:textSize="13sp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>