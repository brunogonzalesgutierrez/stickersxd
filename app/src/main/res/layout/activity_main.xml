<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎭 StickerApp"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:letterSpacing="0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Convertí videos en stickers animados"
                android:textSize="14sp"
                android:textColor="@color/brand_on_surface_dim"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ── PREVIEW CARD ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/brand_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="20dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="300dp">

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Preview del sticker"/>

                <!-- Placeholder centrado -->
                <LinearLayout
                    android:id="@+id/layoutPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvPlaceholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎬"
                        android:textSize="56sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seleccioná un video"
                        android:textSize="15sp"
                        android:textColor="@color/brand_on_surface_dim"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>

                <!-- Badge de tamaño -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/bg_status_badge"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:text="Sin convertir"/>
            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── OPCIONES CARD ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/brand_surface_variant"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Duración -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⏱ Duración"
                        android:textSize="14sp"
                        android:textColor="@color/brand_on_surface"/>

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3s"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary"
                        android:background="@drawable/bg_chip"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/brand_primary"
                    android:thumbTint="@color/brand_primary"
                    android:layout_marginBottom="16dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33FFFFFF"
                    android:layout_marginBottom="16dp"/>

                <!-- Forma -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✂️ Forma del sticker"
                        android:textSize="14sp"
                        android:textColor="@color/brand_on_surface"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleShape"
                        style="@style/Widget.StickerApp.Button.Outline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cuadrado"
                        android:textSize="12sp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── DESDE URL ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/brand_surface_variant"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗  O pegá un link de video"
                    android:textSize="14sp"
                    android:textColor="@color/brand_on_surface"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etVideoUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://..."
                    android:textColor="@color/white"
                    android:textColorHint="@color/brand_on_surface_dim"
                    android:backgroundTint="@color/brand_primary"
                    android:inputType="textUri"
                    android:textSize="13sp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:singleLine="true"/>


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSearchTenor"
                    style="@style/Widget.StickerApp.Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:text="🔍  Buscar GIFs"
                    android:textAllCaps="false"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadUrl"
                    style="@style/Widget.StickerApp.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:text="⚡  Convertir desde link"
                    android:textAllCaps="false"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── PROGRESS BAR ── -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            android:indeterminate="true"
            app:indicatorColor="@color/brand_primary"
            app:trackColor="#33FFFFFF"
            app:trackCornerRadius="4dp"/>

        <!-- ── BOTONES DE ACCIÓN ── -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMyPacks"
            style="@style/Widget.StickerApp.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="🗂  Mis Stickers"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="12dp"/>

        <!-- Seleccionar video -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPick"
            style="@style/Widget.StickerApp.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📁  Seleccionar video"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <!-- Convertir -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConvert"
            style="@style/Widget.StickerApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="⚡  Convertir a Sticker"
            android:textSize="15sp"
            android:enabled="false"
            android:layout_marginBottom="12dp"/>

        <!-- Enviar a WhatsApp -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            style="@style/Widget.StickerApp.Button.Send"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💬  Enviar a WhatsApp"
            android:textSize="15sp"
            android:enabled="false"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>