<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StickerApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="android:windowBackground">@color/brand_surface</item>
        <item name="android:statusBarColor">@color/brand_surface</item>
        <item name="android:navigationBarColor">@color/brand_surface</item>
    </style>

    <!-- Botón primario morado -->
    <style name="Widget.StickerApp.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- Botón outline (Pick) -->
    <style name="Widget.StickerApp.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Botón enviar (verde) -->
    <style name="Widget.StickerApp.Button.Send" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_success</item>
        <item name="android:textColor">@color/brand_surface</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="elevation">4dp</item>
    </style>
</resources>